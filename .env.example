# .env

# ===== Database Configuration =====
DB_NAME=moodle
DB_USERNAME=moodle
DB_PASSWORD=moodle
MOODLE_DB_PORT=28433

# ===== Moodle Configuration =====
USERNAME=admin
PASSWORD=Admin@unreal
EMAIL=admin@unrealuni.edu
SITE_NAME=Unreal University Moodle
MOODLE_PORT=28082
MOODLE_HOST=localhost:28082

# ===== Mailpit Host Ports =====
MAILPIT_SMTP_PORT=28025
MAILPIT_WEB_PORT=28026

# ===== Extra Configuration =====
DEBUG=True

# ===== Keycloak / OIDC Development Configuration =====
KEYCLOAK_HOSTNAME=1up-keycloak.localhost
KEYCLOAK_ISSUER=http://1up-keycloak.localhost:28080/realms/university-dev
KEYCLOAK_CLIENT_ID=moodle
KEYCLOAK_CLIENT_SECRET=moodle-dev-secret

# ===== Middleware / JupyterHub NRW Block =====
MIDDLEWARE_API_HOST=host.docker.internal
MIDDLEWARE_API_PORT=38000
MIDDLEWARE_API_KEY=replace_with_middleware_api_key
